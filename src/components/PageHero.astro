---
interface Props {
  titulo: string;
  subtitulo?: string;
  imagen?: string;
  breadcrumb?: string;
}

const base = import.meta.env.BASE_URL;

const {
  titulo,
  subtitulo,
  imagen: imagenProp = '/slider/slider-1.jpg',
  breadcrumb,
} = Astro.props;

// Agregar BASE_URL si la imagen empieza con /
const imagen = imagenProp.startsWith('/') ? `${base}${imagenProp}` : imagenProp;
---

<div style="position:relative; height:200px; overflow:hidden; background:#3a3a3a">
  <img
    src={imagen}
    alt={titulo}
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.4"
  />
  <div style="position:relative; z-index:1; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center">
    <h1 style="color:#fff; font-size:1.225rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.3rem">
      {titulo}
    </h1>
    {subtitulo && (
      <p style="color:rgba(255,255,255,0.75); font-size:0.905rem; letter-spacing:0.08em; margin-bottom:0.6rem">
        {subtitulo}
      </p>
    )}
    <nav style="display:flex; align-items:center; gap:0.5rem; font-size:0.845rem; color:rgba(255,255,255,0.7)">
      <a href={base} style="color:rgba(255,255,255,0.7); text-decoration:none">Home</a>
      <span>›</span>
      <span style="color:#fff">{breadcrumb ?? titulo}</span>
    </nav>
  </div>
</div>
