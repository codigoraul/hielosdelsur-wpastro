---
const year = new Date().getFullYear();
---

<footer style="background:#1C1C1C; color:#d6d3d1">

  <!-- Main footer -->
  <div class="wrap" style="padding:4rem 0; display:grid; grid-template-columns:repeat(4,1fr); gap:2.5rem">


    <!-- Logo + descripción -->
    <div class="lg:col-span-2">
      <img src="/hielos-de-sur.png" alt="Hielos del Sur" class="h-14 w-auto mb-5 brightness-0 invert" />
      <p class="text-sm text-stone-400 leading-relaxed max-w-xs">
        Mobiliario de calidad para restaurantes, hoteles y espacios gastronómicos. Más de 20 años equipando Chile.
      </p>
      <div class="flex items-center gap-3 mt-6">
        <a href="https://instagram.com" target="_blank" class="w-9 h-9 rounded-full border border-stone-600 flex items-center justify-center hover:border-[#8B7355] hover:text-[#8B7355] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Catálogo -->
    <div>
      <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-5">Catálogo</h4>
      <ul class="flex flex-col gap-3">
        {['Sillas', 'Sillones', 'Taburetes', 'Mesas', 'Bancas'].map(cat => (
          <li>
            <a href={`/catalogo/${cat.toLowerCase()}`} class="text-sm text-stone-400 hover:text-[#8B7355] transition-colors">
              {cat}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contacto -->
    <div>
      <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-5">Contacto</h4>
      <ul class="flex flex-col gap-4 text-sm text-stone-400">
        <li class="flex items-start gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-[#8B7355] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Santa Margarita 0487<br/>San Bernardo, Chile
        </li>
        <li class="flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#8B7355] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:contacto@hielosdelsur.cl" class="hover:text-[#8B7355] transition-colors">
            contacto@hielosdelsur.cl
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-stone-800">
    <div class="wrap py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-stone-500">
      <p>© {year} Hielos del Sur. Todos los derechos reservados.</p>
      <p>Diseño web moderno con Astro JS</p>
    </div>
  </div>
</footer>
