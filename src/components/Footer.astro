---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer style="background:#1C1C1C; color:#d6d3d1">

  <div class="wrap footer-grid">

    <!-- Logo + descripción -->
    <div>
      <img src="./hielos-del-sur-claro.svg" alt="Hielos del Sur" style="height:48px; width:auto; margin-bottom:1.25rem" />
      <p style="font-size:0.84rem; color:#a8a29e; line-height:1.75; max-width:26rem">
        Con más de 25 años de trayectoria, somos una de las principales fábricas de insumos y equipamiento gastronómico del mercado. Con el foco puesto en la creación, diseño y desarrollo, producimos mesas, sillas y todo el mobiliario necesario para Food Courts, Comedores, Instituciones Educativas y Mobiliario Urbano.
      </p>
    </div>

    <!-- Catálogo -->
    <div>
      <h4 style="color:#fff; font-size:0.65rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.5rem">Catálogo</h4>
      <ul style="display:flex; flex-direction:column; gap:0.85rem; list-style:none">
        {['Sillas', 'Sillones', 'Taburetes', 'Mesas', 'Bancas'].map(cat => (
          <li>
            <a href={`${base}catalogo/${cat.toLowerCase()}`} style="font-size:0.875rem; color:#a8a29e; text-decoration:none; transition:color 0.2s"
               onmouseover="this.style.color='#8B7355'" onmouseout="this.style.color='#a8a29e'">
              {cat}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contacto -->
    <div>
      <h4 style="color:#fff; font-size:0.65rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.5rem">Contacto</h4>
      <ul style="display:flex; flex-direction:column; gap:1.1rem; list-style:none">

        <li style="display:flex; align-items:flex-start; gap:0.75rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#8B7355" style="flex-shrink:0; margin-top:2px">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span style="font-size:0.875rem; color:#a8a29e; line-height:1.6">Santa Margarita 0487<br/>San Bernardo, Santiago</span>
        </li>

        <li style="display:flex; align-items:center; gap:0.75rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#8B7355" style="flex-shrink:0">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span style="font-size:0.875rem; color:#a8a29e; line-height:1.6">
            <a href="tel:+5622854 4785" style="color:#a8a29e; text-decoration:none" onmouseover="this.style.color='#8B7355'" onmouseout="this.style.color='#a8a29e'">(+562) 2854 4785</a>
            &nbsp;|&nbsp;
            <a href="tel:+56228540118" style="color:#a8a29e; text-decoration:none" onmouseover="this.style.color='#8B7355'" onmouseout="this.style.color='#a8a29e'">(+562) 2854 0118</a>
          </span>
        </li>

        <li style="display:flex; align-items:center; gap:0.75rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#8B7355" style="flex-shrink:0">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:contacto@hielosdelsur.cl" style="font-size:0.875rem; color:#a8a29e; text-decoration:none"
             onmouseover="this.style.color='#8B7355'" onmouseout="this.style.color='#a8a29e'">
            contacto@hielosdelsur.cl
          </a>
        </li>

        <li style="display:flex; align-items:center; gap:0.75rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="#8B7355" viewBox="0 0 24 24" style="flex-shrink:0">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <a href="https://instagram.com/hielos.del.sur" target="_blank" style="font-size:0.875rem; color:#a8a29e; text-decoration:none"
             onmouseover="this.style.color='#8B7355'" onmouseout="this.style.color='#a8a29e'">
            @hielos.del.sur
          </a>
        </li>

      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div style="border-top:1px solid #2e2e2e">
    <div class="wrap footer-bottom">
      <p style="font-size:0.75rem; color:#57534e">© {year} Hielos del Sur. Todos los derechos reservados.</p>
      <p style="font-size:0.75rem; color:#57534e">
        San Bernardo, Santiago — Chile | Diseño por <a href="https://diseñopaginas.cl" target="_blank" rel="noopener noreferrer" style="color:#8B7355; text-decoration:none; transition:color 0.2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B7355'">diseñopaginas</a>
      </p>
    </div>
  </div>

</footer>

<style>
  .footer-grid {
    padding: 5rem 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .footer-bottom {
    padding: 1.5rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 1.5rem 2.5rem;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      padding: 1.25rem 1.5rem;
    }
  }
</style>