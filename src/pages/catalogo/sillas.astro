---
import Layout from '../../layouts/Layout.astro';
import CatalogGrid from '../../components/CatalogGrid.jsx';
import PageHero from '../../components/PageHero.astro';
import { getProductos, getYoastSEOFromCategory } from '../../lib/wordpress.js';

// Obtener datos de Yoast SEO desde la categoría "sillas"
const yoastData = await getYoastSEOFromCategory('sillas');

const sillas    = await getProductos('sillas');
const taburetes = await getProductos('taburetes');
const productos = [...sillas, ...taburetes];
const filtros = ['Metálicas', 'Plásticas', 'Tapizadas', 'Taburetes', 'Madera'];
---

<Layout 
  title="Sillas — Hielos del Sur"
  yoastData={yoastData}
>

  <PageHero titulo="Sillas" imagen="/slider/slider-1.jpg" breadcrumb="Sillas" />

  <!-- Catálogo -->
  <section style="padding:4rem 0; background:#FAFAFA">
    <div class="wrap">
      <CatalogGrid
        client:load
        productos={productos}
        filtros={filtros}
      />
    </div>
  </section>

</Layout>
