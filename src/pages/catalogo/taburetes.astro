---
import Layout from '../../layouts/Layout.astro';
import CatalogGrid from '../../components/CatalogGrid.jsx';
import PageHero from '../../components/PageHero.astro';
import { getProductos } from '../../lib/wordpress.js';

const productos = await getProductos('taburetes');
const filtros = ['Metálicos', 'Madera', 'Tapizados', 'Con Respaldo', 'Sin Respaldo'];
---

<Layout title="Taburetes — Hielos del Sur">

  <PageHero titulo="Taburetes" imagen="/slider/slider-3.jpg" breadcrumb="Taburetes" />

  <!-- Catálogo -->
  <section style="padding:4rem 0; background:#FAFAFA">
    <div class="wrap">
      <CatalogGrid
        client:load
        productos={productos}
        filtros={filtros}
      />
    </div>
  </section>

</Layout>
