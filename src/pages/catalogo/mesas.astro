---
import Layout from '../../layouts/Layout.astro';
import CatalogGrid from '../../components/CatalogGrid.jsx';
import PageHero from '../../components/PageHero.astro';
import { getProductos } from '../../lib/wordpress.js';

const productos = await getProductos('mesas');
const filtros = ['Bases', 'Cubiertas', 'Terminaciones'];
---

<Layout title="Mesas — Hielos del Sur">

  <PageHero titulo="Mesas" imagen="/slider/slider-2.jpg" breadcrumb="Mesas" />

  <!-- Catálogo -->
  <section style="padding:4rem 0; background:#FAFAFA">
    <div class="wrap">
      <CatalogGrid
        client:load
        productos={productos}
        filtros={filtros}
      />
    </div>
  </section>

</Layout>
