---
import Layout from '../../layouts/Layout.astro';
import CatalogGrid from '../../components/CatalogGrid.jsx';
import PageHero from '../../components/PageHero.astro';
import { getProductos } from '../../lib/wordpress.js';

const productos = await getProductos('sillones');
const filtros = [];
---

<Layout title="Sillones — Hielos del Sur">

  <PageHero titulo="Sillones" imagen="/slider/slider-1.jpg" breadcrumb="Sillones" />

  <!-- Catálogo -->
  <section style="padding:4rem 0; background:#FAFAFA">
    <div class="wrap">
      <CatalogGrid
        client:load
        productos={productos}
        filtros={filtros}
      />
    </div>
  </section>

</Layout>
