---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';

const base = import.meta.env.BASE_URL;

const categorias = [
  {
    label: 'Sillas',
    href: `${base}/catalogo/sillas`,
    image: `${base}/images/sillas.jpg`,
    desc: 'Metálicas, plásticas, tapizadas y más para cada ambiente.',
  },
  {
    label: 'Sillones',
    href: `${base}/catalogo/sillones`,
    image: `${base}/slider/slider-2.jpg`,
    desc: 'Confort y diseño para espacios lounge y salas de espera.',
  },
  {
    label: 'Taburetes',
    href: `${base}/catalogo/taburetes`,
    image: `${base}/slider/slider-3.jpg`,
    desc: 'Ideales para barras y mesones de cocina o café.',
  },
  {
    label: 'Mesas',
    href: `${base}/catalogo/mesas`,
    image: `${base}/slider/slider-2.jpg`,
    desc: 'Cuadradas, redondas y rectangulares en distintos acabados.',
  },
  {
    label: 'Bancas',
    href: `${base}/catalogo/bancas`,
    image: `${base}/slider/slider-1.jpg`,
    desc: 'Tapizadas y en madera para áreas de espera o comedores.',
  },
];
---

<Layout title="Catálogo — Hielos del Sur">

  <PageHero titulo="Catálogo" imagen="/slider/slider-2.jpg" />

  <!-- Grid de categorías -->
  <section style="padding:5rem 0; background:#FAFAFA">
    <div class="wrap">

      <p class="sec-label">Nuestros productos</p>
      <h2 class="sec-title">Elige tu categoría</h2>

      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; margin-top:3rem">
        {categorias.map((cat) => (
          <a
            href={cat.href}
            style="text-decoration:none; display:block; group; overflow:hidden; background:#fff"
          >
            <!-- Imagen -->
            <div style="position:relative; overflow:hidden; aspect-ratio:4/3">
              <img
                src={cat.image}
                alt={cat.label}
                style="width:100%; height:100%; object-fit:cover; transition:transform 0.5s ease"
                onmouseover="this.style.transform='scale(1.05)'"
                onmouseout="this.style.transform='scale(1)'"
              />
              <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35); display:flex; align-items:flex-end; padding:1.5rem">
                <h3 style="color:#fff; font-size:1.1rem; font-weight:800; letter-spacing:0.12em; text-transform:uppercase">
                  {cat.label}
                </h3>
              </div>
            </div>
            <!-- Texto -->
            <div style="padding:1.25rem 0">
              <p style="font-size:0.82rem; color:#78716c; line-height:1.6">
                {cat.desc}
              </p>
              <span style="display:inline-flex; align-items:center; gap:0.4rem; margin-top:0.75rem; font-size:0.7rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#8B7355; border-bottom:2px solid #8B7355; padding-bottom:2px">
                Ver productos
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
