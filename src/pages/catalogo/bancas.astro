---
import Layout from '../../layouts/Layout.astro';
import CatalogGrid from '../../components/CatalogGrid.jsx';
import PageHero from '../../components/PageHero.astro';
import { getProductos } from '../../lib/wordpress.js';

const productos = await getProductos('bancas');
const filtros = ['Tapizadas', 'Madera', 'Metálicas', 'Con Respaldo', 'Sin Respaldo'];
---

<Layout title="Bancas — Hielos del Sur">

  <PageHero titulo="Bancas" imagen="/slider/slider-1.jpg" breadcrumb="Bancas" />

  <!-- Catálogo -->
  <section style="padding:4rem 0; background:#FAFAFA">
    <div class="wrap">
      <CatalogGrid
        client:load
        productos={productos}
        filtros={filtros}
      />
    </div>
  </section>

</Layout>
